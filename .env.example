# Root .env — consumed by docker-compose only.
# Copy to .env and set your own values. Never commit .env.
#
# Generate a secret:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"

# MinIO console + root credentials (full admin — console login at localhost:9001)
MINIO_ROOT_USER=ecivil_admin
MINIO_ROOT_PASSWORD=change-me-generate-your-own

# Least-privilege credentials the API uses. Scoped to the bucket only, never root.
MINIO_APP_ACCESS_KEY=ecivil_app
MINIO_APP_SECRET_KEY=change-me-generate-your-own

MINIO_BUCKET=ecivil-documents
