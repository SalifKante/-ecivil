# Copy to .env and fill in. Never commit .env or put real values here.

NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# MongoDB — matches docker-compose.yml at the repo root
MONGODB_URI=mongodb://localhost:27017/ecivil

# Comma-separated allowed origins
CORS_ORIGIN=http://localhost:5173

# Public base URL of the citizen site, embedded in document QR codes so a scan
# lands on the verification page.
APP_PUBLIC_URL=http://localhost:5173

# Session signing key — min 32 chars. Generate your own, never reuse this placeholder:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-me-with-a-long-random-value-min-32-chars
JWT_EXPIRES_IN=30m

# One-time password lifetime (seconds)
OTP_TTL_SECONDS=300

# Swagger / OpenAPI docs at /api/docs. Set false to disable (e.g. production).
DOCS_ENABLED=true

# MinIO object storage (S3-compatible). Must match the root .env used by docker-compose.
# Use the scoped app credentials here — never the MinIO root user.
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=ecivil_app
MINIO_SECRET_KEY=change-me-generate-your-own
MINIO_BUCKET=ecivil-documents
# Lifetime of presigned download links, in seconds
MINIO_URL_TTL_SECONDS=300
